# ── 수집기 (scripts/collect-trends.mjs · GitHub Actions Secrets) ──
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxx
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # 쓰기용 — 절대 클라이언트에 노출 금지

# ── 뷰어 (Netlify 환경변수) ──
# SUPABASE_URL 은 위와 동일하게 설정
SUPABASE_ANON_KEY=eyJhbGciOi...           # 읽기용 공개 키 (RLS로 보호됨)

# ── 선택 ──
TREND_KEYWORDS=케이팝,챌린지,브이로그,예능,신곡
MAX_ITEMS_PER_PLATFORM=30
# PLATFORMS=youtube,tiktok               # 일부 플랫폼만 수집할 때
# YOUTUBE_ACTOR=streamers~youtube-scraper  # 액터 교체 시 (틱톡 등도 동일 패턴)
